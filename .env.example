# Supabase — copy to .env.local and fill in (never commit .env.local).
# Project URL and anon key from: Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — server-only (migrations/seed/admin tasks). Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=
